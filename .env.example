# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase — get these from your Supabase project dashboard → Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...          # Safe to expose (RLS enforces security)

# Supabase service role — ONLY used in server-side API routes, NEVER sent to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — ONLY used in server-side API routes for report parsing
ANTHROPIC_API_KEY=sk-ant-...

# App
PUBLIC_APP_URL=https://miyagimymatric.com
